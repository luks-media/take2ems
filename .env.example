# SQLite (path relative to prisma/). Docker-Compose nutzt file:./data/ems.db
DATABASE_URL=file:./dev.db

# App & auth
JWT_SECRET=change-me-in-production
# First deploy only: create one ADMIN if the User table is empty (then you can unset these).
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=your-secure-password

# Public base URL (no trailing slash). Used for mail links and Google OAuth redirect.
APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Calendar — Google Cloud: enable Calendar API, OAuth consent, Web client.
# Authorized redirect URI: {APP_URL}/api/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Encrypts the stored refresh token (min. 16 chars; use a long random string in production).
GOOGLE_TOKEN_SECRET=

# SMTP (optional)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
